<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="batch">
	<select id="select_employees" resultType="employees">
		SELECT
			EMP_NO,
			FIRST_NAME
		FROM 
			EMPLOYEES
		LIMIT 1
	</select>
</mapper>